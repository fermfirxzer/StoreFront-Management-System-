DJANGO_SECRET_KEY=django-insecure-change-this-secret-key-for-local-development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Paste the Supabase/Postgres connection string here.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace
DB_SSLMODE=prefer

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Optional Supabase Storage values. They are not required for the main-branch
# local setup, but keep them here so .env.example mirrors the deployment env.
SUPABASE_PROJECT_REF=
SUPABASE_STORAGE_BUCKET=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ENDPOINT_URL=

